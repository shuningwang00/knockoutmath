# Get your API key at https://resend.com
RESEND_API_KEY=re_xxxxxxxx

# Optional: verified sender (e.g. enquiries@knockoutmath.sg after domain setup)
# ENQUIRY_FROM_EMAIL=Knockout Math <enquiries@knockoutmath.sg>

# Optional: live Google star rating on testimonials + in JSON-LD (Places API)
# Enable "Places API" in Google Cloud, then add:
# GOOGLE_PLACES_API_KEY=your_key
# GOOGLE_PLACE_ID=ChIJ...  (from Google Maps → Share → embed, or Place ID finder)

# Optional: after custom domain DNS points to Vercel, set for OG image URLs:
# OG_IMAGE_ORIGIN=https://www.knockoutmath.sg
